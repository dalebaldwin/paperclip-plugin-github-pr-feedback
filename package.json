{
  "name": "paperclip-plugin-github-pr",
  "version": "0.1.6",
  "type": "module",
  "description": "Reliable GitHub pull request feedback, review, and CI intake for Paperclip.",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4178",
    "prepack": "pnpm build",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "github",
    "pull-requests",
    "connector"
  ],
  "author": "Dale Baldwin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dalebaldwin/paperclip-plugin-github-pr-feedback.git"
  },
  "bugs": {
    "url": "https://github.com/dalebaldwin/paperclip-plugin-github-pr-feedback/issues"
  },
  "homepage": "https://github.com/dalebaldwin/paperclip-plugin-github-pr-feedback#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.529.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
